# Deployer private key (DO NOT share or commit this key)
PRIVATE_KEY="your_wallet_private_key_here"

# BscScan API Key for contract source code verification
BSCSCAN_API_KEY="your_bscscan_api_key_here"

# (Optional) Customized Owner and Manager addresses for deployment (defaults to deployer address if unset)
OWNER_ADDRESS="your_owner_address_here"
MANAGER_ADDRESS="your_manager_address_here"
